# Copy to .env and adjust as needed.
# DATABASE_URL matches the Postgres service in docker-compose.yml.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agent_showcase?schema=public"

# Auth.js (NextAuth v5) — GitHub OAuth
# Create a GitHub OAuth app (Settings > Developer settings > OAuth
# Apps), callback: http://localhost:3000/api/auth/callback/github
AUTH_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
